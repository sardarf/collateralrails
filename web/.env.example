# CollateralRails web — network configuration.
#
# Pick ONE chain to run against. Every value below can also be set as a Vercel
# Environment Variable (Project → Settings → Environment Variables), which is what
# makes a Vercel deployment connect to the right chain automatically.
#
# ── 1. Choose the network ──────────────────────────────────────────────────────
# One of: local | arbitrumSepolia | arbitrum | avalancheFuji | avalanche
# (defined in app/config/networks.js — each preset carries the chain id, name,
#  native currency, public RPC and block explorer)
NUXT_PUBLIC_NETWORK=arbitrumSepolia

# ── 2. RPC (optional) ──────────────────────────────────────────────────────────
# Leave blank to use the preset's public RPC. Set it to use a private/faster RPC
# (Alchemy, Infura, etc.) — recommended for testnet/mainnet.
NUXT_PUBLIC_RPC=

# ── 3. Contract addresses (required off `local`) ───────────────────────────────
# Paste the five addresses printed by:
#   forge script script/Deploy.s.sol --rpc-url <network> --broadcast
# On `local` these default to the deterministic anvil addresses and may be blank.
NUXT_PUBLIC_USDC=
NUXT_PUBLIC_REGISTRY=
NUXT_PUBLIC_POLICY=
NUXT_PUBLIC_ROUTER=
NUXT_PUBLIC_CM=

# ── 4. Log scan start block ────────────────────────────────────────────────────
# The block the contracts were deployed at. Keeps event-log queries fast and within
# public-RPC range limits. Use 0 for anvil.
NUXT_PUBLIC_DEPLOY_BLOCK=0