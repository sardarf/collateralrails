# ── deployer ──────────────────────────────────────────────────────────────────
PRIVATE_KEY=
TREASURY=

# ── RPC endpoints (used by forge --rpc-url <alias> and deploy-testnet.sh) ──────
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
AVALANCHE_FUJI_RPC=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_RPC=https://api.avax.network/ext/bc/C/rpc
ROBINHOOD_CHAIN_RPC=

# ── contract verification ─────────────────────────────────────────────────────
ARBISCAN_API_KEY=
SNOWTRACE_API_KEY=

# Optional: browser RPC baked into the Vercel deployment. Leave blank to use the
# network preset's public RPC; set to a private RPC (Alchemy/Infura) for reliability.
WEB_RPC=

# ── demo timing profile (seconds) ─────────────────────────────────────────────
RECEIPT_WINDOW=60
CLAIM_WINDOW=86400
DEFENSE_WINDOW=60
WITHDRAW_COOLDOWN=120